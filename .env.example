# Loom environment: development | test | production
LOOM_ENV=development

# Required database URL. Supabase connection pooler or direct Postgres URL both work.
LOOM_DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# Public API auth. Required in production.
LOOM_API_KEY=change-me

# Internal API token used by the Slack worker to save captured context. Required in production.
LOOM_INTERNAL_API_TOKEN=change-me-too

# API service base URL. Slack worker uses this to call the API service.
LOOM_API_BASE_URL=http://localhost:8000
LOOM_API_HOST=0.0.0.0
LOOM_API_PORT=8000

# LLM provider: deepseek | gemini | claude | openai | skip
# Use skip to disable /ask and Slack gatekeeper summaries.
LOOM_LLM_PROVIDER=deepseek
LOOM_LLM_MODEL_OVERRIDE=
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embeddings. Default semantic search uses Gemini text-embedding-004.
# If GEMINI_API_KEY is missing, Loom falls back to text search.
LOOM_EMBEDDING_PROVIDER=gemini
LOOM_EMBEDDING_MODEL=gemini/text-embedding-004
LOOM_EMBEDDING_DIMENSION=768
LOOM_EMBEDDING_INPUT_MAX_CHARS=3000
LOOM_EMBEDDING_CACHE_SIZE=256

# Slack is optional.
LOOM_SLACK_BOT_TOKEN=xoxb-...
LOOM_SLACK_APP_TOKEN=xapp-...
LOOM_SLACK_SILENT=true

# Memory tuning.
LOOM_MAX_RULES_PER_SESSION=10
LOOM_MAX_CONTEXTS_PER_SESSION=3
LOOM_CONTEXT_MAX_CHARS=500
LOOM_CONTEXT_TTL_DAYS=30
LOOM_BLOB_TTL_DAYS=14
LOOM_CONTEXT_HALF_LIFE_DAYS=10.0

# Slack capture tuning.
LOOM_GATEKEEPER_IDLE_SECONDS=180
LOOM_GATEKEEPER_DEBOUNCE_SECONDS=180
LOOM_SLACK_BUFFER_MAX_MESSAGES=30
LOOM_SLACK_RECONNECT_BACKOFF_MAX_SECONDS=60

# Runtime tuning.
LOOM_HTTP_TIMEOUT_SECONDS=30
LOOM_LLM_TIMEOUT_SECONDS=45
LOOM_LOG_LEVEL=INFO
